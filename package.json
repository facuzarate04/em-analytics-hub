{
	"name": "em-analytics-hub",
	"version": "0.2.0",
	"description": "CMS-aware, portable, privacy-first analytics hub for EmDash. Track pageviews, UTM campaigns, custom events, and more — segmented by route, template, and collection.",
	"type": "module",
	"license": "MIT",
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./sandbox": {
			"types": "./dist/sandbox-entry.d.ts",
			"default": "./dist/sandbox-entry.js"
		},
		"./astro": "./dist/astro/BeaconScript.astro"
	},
	"scripts": {
		"build": "rm -rf dist && tsc && mkdir -p dist/astro && cp -r src/astro/. dist/astro",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm test && npm run build"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/facuzarate04/em-analytics-hub.git"
	},
	"homepage": "https://github.com/facuzarate04/em-analytics-hub#readme",
	"bugs": {
		"url": "https://github.com/facuzarate04/em-analytics-hub/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"peerDependencies": {
		"emdash": "^0.1.0"
	},
	"devDependencies": {
		"emdash": "^0.1.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.2"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"analytics",
		"analytics-hub",
		"utm",
		"privacy",
		"portable"
	]
}
